embed-server --std-out=echo
data-source add --name=PostgresDS \
    --jndi-name=java:jboss/datasources/PostgresDS \
    --driver-name=postgresql-42.7.2.jar \
    --connection-url=jdbc:postgresql://${env.DB_HOST:localhost}:${env.DB_PORT:5432}/${env.DB_NAME:postgres} \
    --user-name=${env.DB_USER:postgres} \
    --password=${env.DB_PASSWORD:password} \
    --use-ccm=false \
    --max-pool-size=25 \
    --blocking-timeout-wait-millis=5000 \
    --enabled=true
stop-embedded-server